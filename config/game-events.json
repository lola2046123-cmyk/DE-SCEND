    "enabled": true,
    "cardsPerRound": 3,
    "preShowDelayMs": 3200,
    "figureAppearMs": 800,
    "cardFlipMs": 600,
    "resultShowMs": 2400,

    "ghostFigures": [
      { "id": "medic",   "src": "assets/subjects/Subject 02.png", "name": "亡灵医师", "weight": 50 },
      { "id": "wraith",  "src": "assets/subjects/Subject 03.png", "name": "血蚀怨灵", "weight": 50 }
    ],

    "identities": [
      { "id": "elder",    "name": "神秘老人",   "glyph": "👴", "weight": 25, "luckBias":  0.05 },
      { "id": "child",    "name": "诡异小孩",   "glyph": "👦", "weight": 20, "luckBias": -0.08 },
      { "id": "handsome", "name": "俊美青年",   "glyph": "🧑", "weight": 20, "luckBias":  0.0  },
      { "id": "woman",    "name": "苍白女人",   "glyph": "👩", "weight": 15, "luckBias":  0.03 },
      { "id": "shadow",   "name": "无面黑影",   "glyph": "🕴️", "weight": 10, "luckBias": -0.12 },
      { "id": "doctor",   "name": "白衣医生",   "glyph": "🧑‍⚕️", "weight": 10, "luckBias":  0.06 }
    ],

    "rewardEvents": [
      { "id": "windfall",         "name": "意外横财",   "description": "墙缝应急金",         "creditsBonusRatio": 0.30, "corruptionDelta": 0,     "weight": 25 },
      { "id": "energy_crystal",   "name": "能量晶体",   "description": "高纯晶体出手",           "creditsBonusRatio": 0.20, "corruptionDelta": 0.05,  "weight": 30 },
      { "id": "audit_pass",       "name": "审计通过",   "description": "审计过关 · 压力缓",     "creditsBonusRatio": 0.10, "corruptionDelta": -0.15, "weight": 20 },
      { "id": "ghost_tip",        "name": "幽灵线报",   "description": "耳边指路",   "creditsBonusRatio": 0.05, "corruptionDelta": -0.10, "weight": 15 },
      { "id": "time_rift",        "name": "时间裂缝",   "description": "时空扭曲 · 资产跳",     "creditsBonusRatio": 0.50, "corruptionDelta": 0.20,  "weight": 8  },
      { "id": "blessed",          "name": "祝福之光",   "description": "暖光罩梯 · 偏移退",     "creditsBonusRatio": 0.08, "corruptionDelta": -0.30, "weight": 7  }
    ],

    "bustEvents": [
      { "id": "ghost_tax",        "name": "亡灵税",     "description": "本层收通行税",           "creditsLossRatio": 0.25, "corruptionDelta": 0.10,  "weight": 25 },
      { "id": "curse",            "name": "楼层诅咒",   "description": "诅咒区 · 资产蚀",         "creditsLossRatio": 0.35, "corruptionDelta": 0.15,  "weight": 20 },
      { "id": "trap_floor",       "name": "陷阱楼层",   "description": "塌陷 · 制动耗资源",   "creditsLossRatio": 0.20, "corruptionDelta": 0.08,  "weight": 22 },
      { "id": "hiss_whisper",     "name": "希斯低语",   "description": "低语入脑 · 偏移飙",   "creditsLossRatio": 0.10, "corruptionDelta": 0.35,  "weight": 18 },
      { "id": "reality_collapse", "name": "现实崩塌",   "description": "空间折 · 资产压",         "creditsLossRatio": 0.50, "corruptionDelta": 0.25,  "weight": 10 },
      { "id": "soul_drain",       "name": "灵魂汲取",   "description": "被抽走生命与账面",       "creditsLossRatio": 0.40, "corruptionDelta": 0.20,  "weight": 10 }
    ],

    "rewardTotalWeight": 0.55,
    "bustTotalWeight": 0.45,

    "_note": "rewardTotalWeight + bustTotalWeight = 1.0。每张卡的收益/爆仓由此概率决定，再在对应池中按 weight 加权随机选取具体事件。identities 的 luckBias 会额外偏移该卡的收益概率。"
  }
}
