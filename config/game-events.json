{
  "_meta": {
    "version": "0.03",
    "description": "《暴富电梯》事件概率与数值配置表（局内计价规程）。修改此文件即可调整游戏平衡，无需改动代码。",
    "lastUpdated": "2026-04-09"
  },

  "thresholds": {
    "_comment": "基础事件带阈值（未受偏移/乘客/环境影响时）。单随机数 r∈[0,1) 按区间映射到四种结果。",
    "liquidationMax": 0.12,
    "negativeMax": 0.25,
    "positiveMax": 0.85
  },

  "outcomeBands": {
    "_comment": "各结果带的资产倍率参数",
    "liquidation": {
      "creditsMultiplier": 0
    },
    "negative": {
      "creditsMultiplierMin": 0.7,
      "creditsMultiplierMax": 0.9
    },
    "positive": {
      "creditsMultiplierMin": 1.1,
      "creditsMultiplierMax": 1.2
    },
    "double": {
      "creditsMultiplier": 2
    }
  },

  "corruption": {
    "_comment": "偏移指数系统。影响清算带宽度，各事件结果后累积不同数值。",
    "max": 3.0,
    "liquidationShift": 0.05,
    "liquidationShiftCap": 0.20,
    "perFloor": 0.08,
    "onPositive": 0.05,
    "onNegative": 0.12,
    "onDouble": 0.35,
    "onReroll": 0.22,
    "onVipAuditRelief": -0.11,
    "onDangerUnveil": 0.17
  },

  "floorLeverage": {
    "_comment": "楼层杠杆系数。养猪期(1-3)平稳，之后指数级扩张。",
    "earlyFloorMax": 3,
    "earlyLeverage": 1.8,
    "growthPerFloor": 0.65,
    "maxLeverage": 8.0
  },

  "pigPeriod": {
    "_comment": "养猪期（前N层保护期）：清算概率锁0，负面限幅。",
    "maxFloor": 3,
    "liquidationLocked": true,
    "negativeMaxRatio": 0.55,
    "negativeMinThreshold": 0.06,
    "maxLossRate": -0.12,
    "stakeFloorToInitialBet": true
  },

  "baselineGrowth": {
    "_comment": "每升一层的基线资产增长倍率",
    "multiplier": 1.1
  },

  "floorsJumped": {
    "_comment": "每次上行随机跳跃的楼层数范围",
    "min": 1,
    "max": 8
  },

  "breach": {
    "_comment": "Hiss Breach（入侵）系统。开门后概率触发，限时内不撤离则自动清算。",
    "baseProbability": 0.10,
    "minFloor": 5,
    "durationMs": 5000,
    "minProbability": 0.028,
    "maxProbability": 0.44,
    "dangerBonus": 0.075,
    "vipReduction": -0.042,
    "vipDangerComboBonus": 0.115
  },

  "passenger": {
    "_comment": "乘客身份系统。控制上下车、类型权重、阈值/资本修正、伪装概率。",
    "maxOnboard": 2,
    "boardChance": 0.40,
    "departChance": 0.30,
    "minFloor": 3,
    "types": {
      "VIP": {
        "weight": 35,
        "liquidationShift": -0.04,
        "negShift": -0.02,
        "creditsMod": 1.15,
        "disguiseChance": 0,
        "volatile": false
      },
      "SCAMMER": {
        "weight": 35,
        "liquidationShift": 0.06,
        "negShift": 0.03,
        "creditsMod": 0.85,
        "disguiseChance": 1.0,
        "volatile": false
      },
      "DANGER": {
        "weight": 30,
        "liquidationShift": 0.08,
        "negShift": 0.02,
        "creditsMod": 1.0,
        "disguiseChance": 0.5,
        "volatile": true
      }
    },
    "combos": {
      "vipScammer": {
        "liquidationShift": 0.035,
        "negShift": 0.02,
        "creditsMult": 1.2
      },
      "vipDanger": {
        "liquidationShift": -0.048,
        "negShift": 0.062,
        "creditsMult": 0.93
      }
    },
    "volatilePositiveChance": 0.6,
    "volatilePositiveMult": 1.25,
    "volatileNegativeMult": 0.75
  },

  "surprise": {
    "_comment": "惊喜事件。非清算后额外掷骰触发，概率随贪婪(楼层)增长。",
    "minFloor": 3,
    "coinRain": {
      "baseProbability": 0.05,
      "creditsBonusRatio": 0.25
    },
    "skipFloor": {
      "baseProbability": 0.04,
      "floorsToSkip": 1
    },
    "greedSaturationFloor": 30
  },

  "envEvents": {
    "_comment": "环境事件。每5层轮换一次，持续至下次覆盖。",
    "triggerInterval": 5,
    "minFloor": 5,
    "events": {
      "LIGHTS_OUT": {
        "description": "熄灯 · 本层倍率隐藏",
        "mechanicEffect": "display_only"
      },
      "CORRUPTION_SURGE": {
        "description": "偏移涨潮 · 增速×2",
        "corruptionMultiplier": 2
      },
      "BAND_DRIFT": {
        "description": "阈值漂移 · 危险带扩",
        "liquidationShiftBonus": 0.028
      }
    }
  },

  "safeNode": {
    "_comment": "伪救赎安全屋。指定楼层首次到达触发，可选净化(扣资产清偏移)或跳过。",
    "floors": [5, 10],
    "purgeCostRatio": 0.20,
    "purgeResetsCorruption": true
  },

  "quota": {
    "_comment": "配额系统。玩家须积累资产超过此值才可正常撤离。",
    "target": 1000,
    "pressureMaxShift": 0.065,
    "pressureLinearFactor": 0.075,
    "nearQuotaRange": 0.2,
    "nearQuotaPeakShift": 0.038
  },

  "speculatorProtocol": {
    "_comment": "激进投机者(SC身份)对赌：确认后未来N层账面收益倍率放大，但结果带来的偏移增速按倍率放大。交互为浏览器原生 confirm（无新 HTML）。",
    "enabled": true,
    "targetIdentity": "SCAMMER",
    "durationFloors": 3,
    "gainMult": 3,
    "corruptionOutcomeMult": 2
  },

  "angelInvestor": {
    "_comment": "天使投资人(VIP)上车：若干层内小幅抬高正面收益率（话术见 copy）。",
    "enabled": true,
    "targetIdentity": "VIP",
    "durationFloors": 2,
    "positiveRateBonus": 0.04
  },

  "rerollBailout": {
    "_comment": "软盘重掷掷中清算时，可支付当前账面一定比例买断并重掷；仍清算则降级为温和负面。",
    "enabled": true,
    "assetPayRatio": 0.4,
    "fallbackCreditsMultiplier": 0.82,
    "useNativeConfirm": true
  },

  "goldenPositive": {
    "_comment": "肥尾：在落入正面带后，按概率升级为超高倍率（仍记为 POSITIVE，兼容现有 UI）。",
    "probability": 0.015,
    "creditsMultiplier": 10
  },

  "chainLightning": {
    "_comment": "连环爆雷：极低概率在负面结算后追加折损，并写入 localStorage 供下一局开局扣除（跨局负债）。",
    "probability": 0.0008,
    "extraLossRatioOfSnapshot": 0.18,
    "storageKey": "fbc_chain_margin_call_v1"
  },

  "assetFreeze": {
    "_comment": "资产冻结：随机锁住部分流动性，再上行若干层归还；提前撤离则额外回吐账面。",
    "probability": 0.035,
    "lockRatio": 0.5,
    "floorsToUnlock": 3,
    "cashoutClawbackRatio": 0.2
  },

  "comboBlindConfidence": {
    "_comment": "连击：进入决策后 windowMs 内上行，本层收益略增，隐性抬高清算带权重（quotaShift）。",
    "windowMs": 1500,
    "gainMult": 1.05,
    "hiddenQuotaShiftBonus": 0.024
  },

  "suspense": {
    "_comment": "清算结局前主线程阻塞等待（毫秒），拉长揭晓张力；0 关闭。低跑道负面可另配延迟。",
    "liquidationBusyWaitMs": 1500,
    "lowRunwayNegativeBusyWaitMs": 1500,
    "lowRunwayCreditsToQuotaMax": 0.22
  },

  "copy": {
    "quotaNudge": "未达配额 ¥${quota}；委员会建议继续上行。\n当前 ¥${credits}；强行撤离将划扣差额 ¥${debt}。",
    "speculatorProtocol": "【对赌】未来 ${durationFloors} 层：正面/翻倍收益×${gainMult}，偏移增速×${corruptionMult}。\n签？取消则照常。",
    "speculatorProtocolScan": "【对赌·揭穿后】同上条款，对方即将下车。\n签？",
    "rerollBailout": "重掷=清算。付 ¥${pay} 重写？（账面 ¥${balance}）\n取消维持清算。"
  },

  "item": {
    "_comment": "物品系统（软盘/模块盘）。初始数量、模式、制动保留比例。",
    "floppyDisk": {
      "initialCount": 3,
      "brakeRetainRatio": 0.30
    }
  },

  "bossChallenge": {
    "_comment": "委员会质询。撤离时若连胜达标且命中概率则弹出质询。",
    "minConsecutiveWins": 2,
    "triggerProbability": 0.30
  },

  "uiPacing": {
    "_comment": "开门后主流程节拍：避免叙事/金额/惊喜/弹窗在同一帧抢拍。单位 ms。",
    "narrativeFlashMs": 680,
    "deltaFlashMs": 1200,
    "afterDeltaHoldMs": 420,
    "safeNodeOverlayDelayMs": 960,
    "surpriseAfterDeltaMs": 320,
    "odometerDelayAfterOpenMs": 160,
    "passengerResyncDelayMs": 560,
    "liquidationPanelDelayMs": 780,
    "postCardToBreachMs": 240,
    "rerollSceneClearMs": 1080,
    "gainFlashHoldMultTier1": 1.32,
    "gainFlashHoldMultTier2": 1.58,
    "gainFlashHoldMultTier3": 1.98,
    "gainFlashHoldMultTier4": 2.45,
    "cardRewardResultMultTier1": 1.22,
    "cardRewardResultMultTier2": 1.45,
    "cardRewardResultMultTier3": 1.72,
    "cardRewardResultMultTier4": 2.02
  },

  "biome": {
    "_comment": "场景Biome切换。按楼层范围自动换肤。",
    "ranges": [
      { "minFloor": 1,  "maxFloor": 10, "biome": "admin" },
      { "minFloor": 11, "maxFloor": 25, "biome": "maintenance" },
      { "minFloor": 26, "maxFloor": 9999, "biome": "supernatural" }
    ]
  },

