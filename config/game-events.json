{
  "_meta": {
    "version": "0.05",
    "description": "《暴富电梯》事件概率与数值配置表（局内计价规程）。修改此文件即可调整游戏平衡，无需改动代码。v0.05：删卡牌/连环爆雷/资产冻结/软盘重掷买断；新增封存货舱选盘 + 货舱清点逐项揭露 + FBC 代决议。",
    "lastUpdated": "2026-04-26"
  },

  "thresholds": {
    "_comment": "基础事件带阈值（未受偏移/乘客/环境影响时）。单随机数 r∈[0,1) 按区间映射到四种结果。",
    "liquidationMax": 0.12,
    "negativeMax": 0.25,
    "positiveMax": 0.85
  },

  "outcomeBands": {
    "_comment": "各结果带的资产倍率参数",
    "liquidation": { "creditsMultiplier": 0 },
    "negative":    { "creditsMultiplierMin": 0.7, "creditsMultiplierMax": 0.9 },
    "positive":    { "creditsMultiplierMin": 1.1, "creditsMultiplierMax": 1.2 },
    "double":      { "creditsMultiplier": 2 }
  },

  "corruption": {
    "_comment": "偏移指数系统。影响清算带宽度，各事件结果后累积不同数值。",
    "max": 3.0,
    "liquidationShift": 0.05,
    "liquidationShiftCap": 0.20,
    "perFloor": 0.08,
    "onPositive": 0.05,
    "onNegative": 0.12,
    "onDouble": 0.35,
    "onVipAuditRelief": -0.11,
    "onDangerUnveil": 0.17,
    "onCommitteeOverride": 0.45
  },

  "floorLeverage": {
    "_comment": "楼层杠杆系数。养猪期(1-3)平稳，之后指数级扩张。",
    "earlyFloorMax": 3,
    "earlyLeverage": 1.8,
    "growthPerFloor": 0.65,
    "maxLeverage": 8.0
  },

  "pigPeriod": {
    "_comment": "养猪期（前N层保护期）：清算概率锁0，负面限幅。",
    "maxFloor": 3,
    "liquidationLocked": true,
    "negativeMaxRatio": 0.55,
    "negativeMinThreshold": 0.06,
    "maxLossRate": -0.12,
    "stakeFloorToInitialBet": true
  },

  "baselineGrowth": {
    "_comment": "每升一层的基线资产增长倍率",
    "multiplier": 1.1
  },

  "floorsJumped": {
    "_comment": "每次上行随机跳跃的楼层数范围",
    "min": 1,
    "max": 8
  },

  "breach": {
    "_comment": "Hiss Breach（入侵）系统。开门后概率触发，限时内不撤离则自动清算。",
    "baseProbability": 0.10,
    "minFloor": 5,
    "durationMs": 5000,
    "minProbability": 0.028,
    "maxProbability": 0.44,
    "dangerBonus": 0.075,
    "vipReduction": -0.042,
    "vipDangerComboBonus": 0.115
  },

