    "maxOnboard": 2,
    "boardChance": 0.40,
    "departChance": 0.30,
    "minFloor": 3,
    "types": {
      "VIP": {
        "weight": 28,
        "liquidationShift": -0.04,
        "negShift": -0.02,
        "creditsMod": 1.15,
        "disguiseChance": 0,
        "volatile": false,
        "label": "监理员"
      },
      "SCAMMER": {
        "weight": 28,
        "liquidationShift": 0.06,
        "negShift": 0.03,
        "creditsMod": 0.85,
        "disguiseChance": 1.0,
        "volatile": false,
        "label": "红圈商人"
      },
      "DANGER": {
        "weight": 22,
        "liquidationShift": 0.08,
        "negShift": 0.02,
        "creditsMod": 1.0,
        "disguiseChance": 0.5,
        "volatile": true,
        "label": "希斯潜伏者"
      },
      "INFORMER": {
        "weight": 14,
        "liquidationShift": 0.0,
        "negShift": 0.0,
        "creditsMod": 1.0,
        "disguiseChance": 0,
        "volatile": false,
        "label": "内线情报员",
        "lockerHintChance": 0.85,
        "lockerHintAccuracy": 0.78
      },
      "CLEANER": {
        "weight": 8,
        "liquidationShift": -0.01,
        "negShift": -0.01,
        "creditsMod": 1.0,
        "disguiseChance": 0,
        "volatile": false,
        "label": "清扫员",
        "lockerHintChance": 0.45,
        "lockerHintAccuracy": 0.55
      }
    },
    "combos": {
      "vipScammer": { "liquidationShift": 0.035, "negShift": 0.02,  "creditsMult": 1.2  },
      "vipDanger":  { "liquidationShift": -0.048, "negShift": 0.062, "creditsMult": 0.93 }
    },
    "volatilePositiveChance": 0.6,
    "volatilePositiveMult": 1.25,
    "volatileNegativeMult": 0.75
  },

  "surprise": {
    "_comment": "惊喜事件。非清算后额外掷骰触发，概率随贪婪(楼层)增长。",
    "minFloor": 3,
    "coinRain":  { "baseProbability": 0.05, "creditsBonusRatio": 0.25 },
    "skipFloor": { "baseProbability": 0.04, "floorsToSkip": 1 },
    "greedSaturationFloor": 30
  },

  "envEvents": {
    "_comment": "环境事件。每5层轮换一次，持续至下次覆盖。",
    "triggerInterval": 5,
    "minFloor": 5,
    "events": {
      "LIGHTS_OUT":       { "description": "熄灯 · 本层倍率隐藏", "mechanicEffect": "display_only" },
      "CORRUPTION_SURGE": { "description": "偏移涨潮 · 增速×2",   "corruptionMultiplier": 2 },
      "BAND_DRIFT":       { "description": "阈值漂移 · 危险带扩",   "liquidationShiftBonus": 0.028 }
    }
  },

  "safeNode": {
    "_comment": "伪救赎安全屋。指定楼层首次到达触发，可选净化(扣资产清偏移)或跳过。",
    "floors": [5, 10],
    "purgeCostRatio": 0.20,
    "purgeResetsCorruption": true
  },

  "quota": {
    "_comment": "配额系统。玩家须积累资产超过此值才可正常撤离。",
    "target": 1000,
    "pressureMaxShift": 0.065,
    "pressureLinearFactor": 0.075,
    "nearQuotaRange": 0.2,
    "nearQuotaPeakShift": 0.038
  },

  "speculatorProtocol": {
    "_comment": "激进投机者(SC身份)对赌：确认后未来N层账面收益倍率放大，但结果带来的偏移增速按倍率放大。交互为浏览器原生 confirm（无新 HTML）。",
    "enabled": true,
    "targetIdentity": "SCAMMER",
    "durationFloors": 3,
    "gainMult": 3,
    "corruptionOutcomeMult": 2
  },

  "angelInvestor": {
    "_comment": "天使投资人(VIP)上车：若干层内小幅抬高正面收益率（话术见 copy）。",
    "enabled": true,
    "targetIdentity": "VIP",
    "durationFloors": 2,
    "positiveRateBonus": 0.04
  },

  "goldenPositive": {
    "_comment": "肥尾：在落入正面带后，按概率升级为超高倍率（仍记为 POSITIVE，兼容现有 UI）。",
    "probability": 0.015,
    "creditsMultiplier": 10
  },

  "comboBlindConfidence": {
    "_comment": "连击：进入决策后 windowMs 内上行，本层收益略增，隐性抬高清算带权重（quotaShift）。",
    "windowMs": 1500,
    "gainMult": 1.05,
    "hiddenQuotaShiftBonus": 0.024
  },

  "suspense": {
    "_comment": "清算结局前主线程阻塞等待（毫秒），拉长揭晓张力；0 关闭。低跑道负面可另配延迟。",
    "liquidationBusyWaitMs": 1500,
    "lowRunwayNegativeBusyWaitMs": 1500,
    "lowRunwayCreditsToQuotaMax": 0.22
  },

  "copy": {
    "quotaNudge":          "未达配额 ¥${quota}；委员会建议继续上行。\n当前 ¥${credits}；强行撤离将划扣差额 ¥${debt}。",
    "speculatorProtocol":  "【对赌】未来 ${durationFloors} 层：正面/翻倍收益×${gainMult}，偏移增速×${corruptionMult}。\n签？取消则照常。",
    "speculatorProtocolScan": "【对赌·揭穿后】同上条款，对方即将下车。\n签？"
  },

