  "fbcOverride": {
    "_comment": "FBC 代决议：玩家未在倒计时内选盘时由委员会代为开柜。代决议无视玩家意志、追加偏移指数，并把账面结算上限按 ratio 折扣。生涯档案累计 total_committee_overrides 用于嘲讽评估。",
    "enabled": true,
    "creditsClampRatio": 0.62,
    "extraCorruption": 0.45,
    "banner": "FBC · 委员会代决议 · 强制开启 LOT-{{lot}}",
    "messages": [
      "委员会代决议：${locker} 号货舱已强制开启。",
      "FBC 自动派发：${locker} 号——决策迟疑视同放弃异议。",
      "联邦垂直局已替您处理 ${locker} 号货舱。\n剩余收益按规章折扣留存。",
      "代决议执行：${locker} 号。\n请下次更果断地行使探测员裁量权。",
      "${locker} 号已被委员会接管。\n您的犹豫已被记入信用档案。"
    ]
  },

